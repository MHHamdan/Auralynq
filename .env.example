# ============================================================================
# Auralynq configuration — copy to `.env` and edit. ALL settings are optional
# except HUGGINGFACE_TOKEN (only required for gated models/datasets, e.g.
# pyannote diarization). The system runs fully local at $0 without any keys.
# Every variable is prefixed with AURALYNQ_ except the well-known token names.
# ============================================================================

# ---- Required only for gated HF assets (diarization, some datasets) ----
HUGGINGFACE_TOKEN=

# ---- Core ----
AURALYNQ_ENV=local                 # local | dev | prod
AURALYNQ_LOG_LEVEL=INFO
AURALYNQ_LOG_JSON=false            # true => structured JSON logs
AURALYNQ_DATA_DIR=./data
AURALYNQ_REPORTS_DIR=./reports
AURALYNQ_SEED=42

# ---- Embeddings ----
AURALYNQ_EMBEDDING__PROVIDER=auto  # auto | bge | hash | openai
AURALYNQ_EMBEDDING__MODEL=BAAI/bge-m3
AURALYNQ_EMBEDDING__DIM=1024       # used by hash fallback / collection sizing
AURALYNQ_EMBEDDING__DEVICE=auto    # auto | cpu | cuda

# ---- Vector store (Qdrant) ----
AURALYNQ_VECTOR__BACKEND=auto      # auto | qdrant | memory
AURALYNQ_VECTOR__URL=http://localhost:6333
AURALYNQ_VECTOR__COLLECTION=auralynq
AURALYNQ_VECTOR__QUANTIZATION=none # none | scalar | binary

# ---- Reranking ----
AURALYNQ_RERANK__PROVIDER=auto     # auto | bge | cohere | none
AURALYNQ_RERANK__MODEL=BAAI/bge-reranker-v2-m3

# ---- Retrieval / router ----
AURALYNQ_RETRIEVAL__TOP_K=20
AURALYNQ_RETRIEVAL__FINAL_K=6
AURALYNQ_RETRIEVAL__RRF_K=60

# ---- LLM generation ----
AURALYNQ_LLM__PROVIDER=auto        # auto | ollama | openai | anthropic | cohere | extractive
AURALYNQ_LLM__MODEL=llama3.2:3b
AURALYNQ_LLM__BASE_URL=http://localhost:11434
AURALYNQ_LLM__TEMPERATURE=0.1
AURALYNQ_LLM__MAX_TOKENS=1024

# ---- Agent loop ----
AURALYNQ_AGENT__MAX_ITERS=3
AURALYNQ_AGENT__LATENCY_BUDGET_MS=15000
AURALYNQ_AGENT__SEMANTIC_CACHE=true

# ---- Voice ----
AURALYNQ_VOICE__ASR_PROVIDER=auto  # auto | faster_whisper | whisperx | null
AURALYNQ_VOICE__ASR_MODEL=base
AURALYNQ_VOICE__TTS_PROVIDER=auto  # auto | kokoro | null
AURALYNQ_VOICE__DIARIZE=true
AURALYNQ_VOICE__VAD=true

# ---- Serving ----
AURALYNQ_SERVE__HOST=0.0.0.0
AURALYNQ_SERVE__PORT=8000
AURALYNQ_SERVE__RATE_LIMIT_PER_MIN=120
# Per-upload size cap for /ingest and /voice (applied at the API layer).
# The Caddy proxy enforces an independent hard cap via AURALYNQ_MAX_BODY_SIZE.
AURALYNQ_SERVE__MAX_UPLOAD_MB=50
# Caddy proxy hard cap on incoming request bodies (prevents DoS before API layer).
AURALYNQ_MAX_BODY_SIZE=100MB
# Optional bearer-token auth. Empty == open (local/demo). When set, every endpoint
# except /health and /metrics requires `Authorization: Bearer <key>`.
AURALYNQ_SERVE__API_KEY=

# ---- Container images (podman-compose ${...} substitution) ----
# Which images compose runs. Defaults to locally-built images at the package
# version. Point at GHCR to deploy a pinned published version:
#   AURALYNQ_IMAGE_PREFIX=ghcr.io/<owner>/auralynq-   AURALYNQ_IMAGE_TAG=0.1.0
AURALYNQ_IMAGE_PREFIX=auralynq-
AURALYNQ_IMAGE_TAG=0.1.0
# Registry/namespace for `make push` (build/push scripts). Lowercase for GHCR.
AURALYNQ_REGISTRY=ghcr.io
AURALYNQ_IMAGE_NAMESPACE=<owner-lowercase>

# ---- Containerized remote deployment (podman-compose ${...} substitution) ----
# Single public HTTPS port via the Caddy TLS proxy (only service on 0.0.0.0).
AURALYNQ_HTTPS_PORT=8443
AURALYNQ_CERT_HOST=localhost          # self-signed cert SAN (server IP or domain)
AURALYNQ_SITE_ADDRESS=:8443           # or https://your.domain for Let's Encrypt
AURALYNQ_BIND_INTERNAL=127.0.0.1      # internal services bind here (off public NIC)
AURALYNQ_WEB_PORT=3000                # web UI loopback publish (debug only)
# Browser → same-origin proxy (no IP/secret in the bundle); CORS = the HTTPS origin.
NEXT_PUBLIC_API_BASE=/api
# CORS origins — defaults to strict loopback for local dev. For a deployed stack,
# set this to the exact HTTPS origin(s) serving the UI. Wildcards ("*") are unsafe.
# AURALYNQ_SERVE__CORS_ORIGINS=["https://<SERVER_IP>:8443"]

# ---- MCP server ----
AURALYNQ_MCP_TRANSPORT=stdio          # stdio | streamable-http | sse
AURALYNQ_MCP_HOST=0.0.0.0             # bind for HTTP transports
AURALYNQ_MCP_PORT=8765
# Bearer auth on the HTTP MCP transports. Empty == open (stdio/local). When set,
# remote clients must send `Authorization: Bearer <key>`. Falls back to
# AURALYNQ_SERVE__API_KEY if this is empty.
AURALYNQ_MCP_API_KEY=

# ---- Air-gap / local-only safeguard ----
# Set to true to guarantee zero data egress to external LLM/embedding/telemetry
# providers regardless of which API keys are present. Forces the "auto" factory
# to resolve only to Ollama (if reachable) or the built-in extractive fallback.
# Langfuse export is also suppressed. Recommended for sensitive deployments.
AURALYNQ_AIR_GAPPED=false

# ---- Telemetry ----
AURALYNQ_TELEMETRY__ENABLED=true
AURALYNQ_TELEMETRY__PHOENIX_ENDPOINT=http://localhost:6006
AURALYNQ_TELEMETRY__OTLP_ENDPOINT=
# Strip PII (emails, phone numbers, SSNs, IPs, card numbers) from trace
# inputs/outputs before they are exported to Langfuse or Phoenix. Default: true.
# Set to false only when you have an explicit legal basis to store raw queries.
AURALYNQ_TELEMETRY__PII_FILTER=true
# Langfuse (hosted trace/eval). Activated when both LANGFUSE_* keys are set AND
# the langfuse SDK is installed (`pip install 'auralynq[telemetry]'`). Self-host?
# set the host below; default is Langfuse Cloud.
AURALYNQ_TELEMETRY__LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Optional paid providers (auto-detected; never required) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
# Langfuse keys — both required to enable hosted tracing (see telemetry above).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
